{
  "name": "pricing-intelligence-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered SaaS pricing intelligence platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm run --filter \"./apps/*\" build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "test": "pnpm run --filter \"./apps/*\" test",
    "lint": "pnpm run --filter \"./apps/*\" lint",
    "lint:architecture": "steiger apps/frontend/src",
    "format": "pnpm run --filter \"./apps/*\" format",
    "clean": "pnpm run --filter \"./apps/*\" clean && rm -rf node_modules",
    "db:generate": "pnpm --filter backend db:generate",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:push": "pnpm --filter backend db:push",
    "db:studio": "pnpm --filter backend db:studio"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "prettier": "^3.9.5",
    "steiger": "^0.6.0",
    "typescript": "^5.9.3"
  }
}
