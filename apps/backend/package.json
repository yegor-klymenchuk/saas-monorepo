{
  "name": "backend",
  "version": "1.0.0",
  "description": "Pricing Intelligence Platform - Backend API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "author": "Yegor",
  "license": "ISC",
  "dependencies": {
    "@ts-rest/core": "3.53.0-rc.1",
    "@ts-rest/express": "3.53.0-rc.1",
    "better-auth": "^1.4.9",
    "contracts": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "pg": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.8",
    "prettier": "^3.5.3",
    "supertest": "^7.2.2",
    "tsx": "4.19.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  }
}
